# ChurnGuard Frontend Environment Variables
# Copy to .env and fill in your values

# URL of the FastAPI backend (EC2 Elastic IP for production, localhost for dev)
VITE_API_URL=http://localhost:8000

# Supabase (for client-side auth only — anon key is safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
